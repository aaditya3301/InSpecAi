# Copy this file to ".env" (no extension) and paste your NEW Hugging Face token.
# Get one at: https://huggingface.co/settings/tokens
# A read-only token is enough.
#
# IMPORTANT: do NOT commit the real .env to git. Add ".env" to your .gitignore.

HF_TOKEN=hf_paste_your_new_token_here
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
