# Copy this file to ".env" inside the backend folder if you need local
# environment configuration.
#
# Do not commit a real ".env" file.

# Optional: Hugging Face token for private or gated models.
HF_TOKEN=hf_your_token_here

# Optional: Neon/Postgres connection string for saved image analyses and
# benchmark history.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Optional: Hugging Face image-model device.
# Use -1 for CPU, or 0 for CUDA device 0.
INSPEC_DEVICE=-1
